# Keep text files consistent across Windows, macOS, Linux, and CI.
* text=auto eol=lf

# Windows command scripts require CRLF for broad compatibility.
*.bat text eol=crlf
*.cmd text eol=crlf

# Treat common media and font assets as binary.
*.gif binary
*.ico binary
*.jpg binary
*.jpeg binary
*.png binary
*.webp binary
*.woff binary
*.woff2 binary
