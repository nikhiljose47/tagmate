E2E_USER2_PASSWORD=replace-with-test-password
E2E_USER2_NAME=UserTwo

E2E_USER3_EMAIL=e2e-user-3@example.invalid
E2E_USER3_PASSWORD=replace-with-test-password
E2E_USER3_NAME=UserThree

E2E_USER4_EMAIL=e2e-user-4@example.invalid
E2E_USER4_PASSWORD=replace-with-test-password
E2E_USER4_NAME=UserFour

