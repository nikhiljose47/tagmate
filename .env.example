# E2E Test Credentials
# You can customize these if you want to run tests against your own seeded users.

# Default password fallback if individual passwords are not set
E2E_TEST_PASSWORD=replace-with-test-password

E2E_USER1_EMAIL=e2e-user-1@example.invalid
E2E_USER1_PASSWORD=replace-with-test-password
E2E_USER1_NAME=UserOne

